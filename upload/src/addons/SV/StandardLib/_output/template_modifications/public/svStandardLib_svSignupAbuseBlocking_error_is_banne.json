{
    "template": "svSignupAbuseBlocking_error_is_banned",
    "description": "XF2.1/XF2.2/XF2.3 Rewrite logout link to use link-post",
    "execution_order": 1,
    "enabled": true,
    "action": "str_replace",
    "find": "href=\"{{ link('login/logout', null, {'t': csrf_token()}) }}\"",
    "replace": "href=\"{{ link('login/logout') }}\" data-xf-click=\"link-post\""
}